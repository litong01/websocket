# Kinde: your Kinde domain (e.g. myapp for myapp.kinde.com)
KINDE_DOMAIN=myapp
# Optional: validate JWT audience
# KINDE_AUDIENCE=your-api-audience

# Server
# HOST=0.0.0.0
# PORT=8080

# WebSocket: close connection after this many seconds with no activity (default 7200 = 2 hours; 0 = disabled)
# IDLE_TIMEOUT_SECS=7200

# Logging
# RUST_LOG=info
